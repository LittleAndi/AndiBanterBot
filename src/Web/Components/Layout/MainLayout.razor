@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <button type="button" class="show-nav-button" onclick="toggleNavMenu()" title="Show navigation" aria-label="Show navigation">
        <svg viewBox="0 0 16 16" aria-hidden="true">
            <path d="M2.5 3h11a.5.5 0 0 1 0 1h-11a.5.5 0 0 1 0-1Zm3.146 2.146a.5.5 0 0 1 .708 0l2.5 2.5a.5.5 0 0 1 0 .708l-2.5 2.5a.5.5 0 0 1-.708-.708L7.793 8 5.646 5.854a.5.5 0 0 1 0-.708ZM2.5 12h11a.5.5 0 0 1 0 1h-11a.5.5 0 0 1 0-1Z" />
        </svg>
    </button>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
