@page "/pubsubcallback"
@using System.Web
@using System.Text.Json.Serialization
@using Microsoft.AspNetCore.Components.Web
@using Web.Components.Services
@inject NavigationManager NavigationManager
@inject TwitchApiClient TwitchApiClient
@rendermode InteractiveServer

<PageTitle>PubSub OAuth Callback</PageTitle>

<h1>PubSub OAuth Callback</h1>

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger">
        Error: @error
    </div>
}
else if (!string.IsNullOrEmpty(accessToken))
{
    <div class="alert alert-success">
        Successfully authenticated! Starting services...
    </div>
}
else
{
    <div>Processing...</div>
}

@code {
    private string? error;
    private string? accessToken;
    private HttpClient httpClient = new();

    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = HttpUtility.ParseQueryString(uri.Query);

        var code = query["code"];
        var scopes = query["scope"];

        if (string.IsNullOrEmpty(code))
        {
            error = "No authorization code received";
            return;
        }

        if (string.IsNullOrEmpty(scopes))
        {
            error = "No scopes received";
            return;
        }

        var redirectUri = NavigationManager.BaseUri + "pubsubcallback";
        var success = await TwitchApiClient.SendAuthCode(code, scopes, redirectUri);

        if (!success)
        {
            error = "Twitch service rejected the authorization code";
            return;
        }

        accessToken = code;
        StateHasChanged();

        await Task.Delay(1000);
        NavigationManager.NavigateTo("/broadcaster/status");
    }
}
