@page "/twitchlogin"
@using System.Web
@using Web.Components.Services
@inject NavigationManager Navigator
@inject TwitchApiClient TwitchApiClient
@rendermode InteractiveServer

<PageTitle>Twitch Login</PageTitle>

<h1>Get User Access Tokens</h1>

@if (status is null)
{
    <div class="alert alert-warning">
        Could not reach the Twitch service, status is unknown.
    </div>
}
else
{
    <div class="alert @(status.WebSocketConnected ? "alert-success" : "alert-secondary")">
        EventSub websocket: @(status.WebSocketConnected ? "connected" : "not connected")
        @if (status.LastMessageAtUtc is not null)
        {
            <span> — last message @status.LastMessageAtUtc.Value.ToLocalTime().ToString("g")</span>
        }
    </div>
}

<div class="mb-3">
    <h5>Bot account @RoleBadge(status?.Bot)</h5>
    <a href='@botUrl'>Authorize Bot with bot account</a>
</div>
<div class="mb-3">
    <h5>Broadcaster account @RoleBadge(status?.Broadcaster)</h5>
    <a href='@streamerUrl'>Authorize Bot with stream account</a>
</div>

<div class="mb-3">
    <h5>Send chat message</h5>
    <div class="input-group" style="max-width: 480px;">
        <input class="form-control" @bind="chatMessage" @bind:event="oninput"
               placeholder="Message to the channel" @onkeyup="@(e => e.Key == "Enter" ? SendChat() : Task.CompletedTask)" />
        <button class="btn btn-primary" @onclick="SendChat" disabled="@(sending || string.IsNullOrWhiteSpace(chatMessage))">Send</button>
    </div>
    @if (sendFeedback is not null)
    {
        <div class="form-text @(sendSucceeded ? "text-success" : "text-danger")">@sendFeedback</div>
    }
</div>

@code {
    [Inject]
    private IConfiguration Configuration { get; set; } = default!;

    private string botUrl = string.Empty;
    private string streamerUrl = string.Empty;
    private AuthStatusResponse? status;
    private string chatMessage = string.Empty;
    private bool sending;
    private bool sendSucceeded;
    private string? sendFeedback;

    protected override void OnInitialized()
    {
        var clientId = Configuration["TwitchLib:ClientId"]!;
        var botScopes = BuildScopes(Configuration!.GetSection("TwitchLib:BotScopes")!.Get<string[]>()!);
        var broadcasterScopes = BuildScopes(Configuration!.GetSection("TwitchLib:BroadcasterScopes")!.Get<string[]>()!);

        botUrl = $"https://id.twitch.tv/oauth2/authorize?response_type=code&client_id={clientId}&redirect_uri={HttpUtility.UrlEncode(Navigator.BaseUri + "callback")}&scope={botScopes}";

        streamerUrl = $"https://id.twitch.tv/oauth2/authorize?response_type=code&client_id={clientId}&redirect_uri={HttpUtility.UrlEncode(Navigator.BaseUri + "pubsubcallback")}&scope={broadcasterScopes}";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            status = await TwitchApiClient.GetAuthStatus();
            StateHasChanged();
        }
    }

    private async Task SendChat()
    {
        if (sending || string.IsNullOrWhiteSpace(chatMessage)) return;

        sending = true;
        try
        {
            var result = await TwitchApiClient.SendChatMessage(chatMessage);
            sendSucceeded = result.Sent;
            sendFeedback = result.Sent ? "Message sent." : result.DropReason ?? "Message was not sent.";
            if (result.Sent)
            {
                chatMessage = string.Empty;
            }
        }
        finally
        {
            sending = false;
        }
    }

    private static string RoleBadge(RoleStatus? role) => role switch
    {
        null => "— not logged in",
        { NeedsLogin: true } => $"— {role.Login}: login expired, please log in again",
        _ => $"— logged in as {role.Login}",
    };

    private static string BuildScopes(string[] scopes)
    {
        // Url encode the scopes string
        return HttpUtility.UrlEncode(string.Join(" ", scopes));
    }

}
