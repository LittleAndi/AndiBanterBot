@page "/twitchlogin"
@using Web.Components.Dashboard
@using Web.Components.Services
@inject NavigationManager Navigator
@inject TwitchApiClient TwitchApiClient
@inject TwitchAuthUrlBuilder AuthUrlBuilder
@rendermode InteractiveServer

<PageTitle>Twitch Login</PageTitle>

<div class="twitch-login">
    <h1 class="twitch-login-title">Get User Access Tokens</h1>

    @if (status is null)
    {
        <div class="alert alert-warning">
            Could not reach the Twitch service, status is unknown.
        </div>
    }

    <div class="twitch-login-grid">
        <AccountCard Title="Bot account" Role="status?.Bot" AuthorizeUrl="@botUrl" ActionLabel="Authorize Bot with bot account"
                     Connection="status?.BotConnection" ConnectionLabel="EventSub websocket (chat)" />
        <AccountCard Title="Broadcaster account" Role="status?.Broadcaster" AuthorizeUrl="@streamerUrl" ActionLabel="Authorize Bot with stream account"
                     Connection="status?.BroadcasterConnection" ConnectionLabel="EventSub websocket (redemptions, raids, follows, subs, cheers, stream status)" />
    </div>

    <ChatSendBox />
</div>

@code {
    private string botUrl = string.Empty;
    private string streamerUrl = string.Empty;
    private AuthStatusResponse? status;

    protected override void OnInitialized()
    {
        botUrl = AuthUrlBuilder.BuildBotAuthorizeUrl(Navigator.BaseUri);
        streamerUrl = AuthUrlBuilder.BuildBroadcasterAuthorizeUrl(Navigator.BaseUri);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            status = await TwitchApiClient.GetAuthStatus();
            StateHasChanged();
        }
    }
}
