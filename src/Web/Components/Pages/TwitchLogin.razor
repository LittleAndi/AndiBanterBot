@page "/twitchlogin"
@using Web.Components.Dashboard
@using Web.Components.Services
@inject NavigationManager Navigator
@inject TwitchApiClient TwitchApiClient
@inject TwitchAuthUrlBuilder AuthUrlBuilder
@rendermode InteractiveServer

<PageTitle>Twitch Login</PageTitle>

<h1>Get User Access Tokens</h1>

@if (status is null)
{
    <div class="alert alert-warning">
        Could not reach the Twitch service, status is unknown.
    </div>
}
else
{
    <div class="alert @(status.BotConnection.Connected ? "alert-success" : "alert-secondary")">
        Bot EventSub websocket (chat): @(status.BotConnection.Connected ? "connected" : "not connected")
        @if (status.BotConnection.LastMessageAtUtc is not null)
        {
            <span> — last message @status.BotConnection.LastMessageAtUtc.Value.ToLocalTime().ToString("g")</span>
        }
    </div>
    <div class="alert @(status.BroadcasterConnection.Connected ? "alert-success" : "alert-secondary")">
        Broadcaster EventSub websocket (redemptions, raids, follows, subs, cheers, stream status): @(status.BroadcasterConnection.Connected ? "connected" : "not connected")
        @if (status.BroadcasterConnection.LastMessageAtUtc is not null)
        {
            <span> — last message @status.BroadcasterConnection.LastMessageAtUtc.Value.ToLocalTime().ToString("g")</span>
        }
    </div>
}

<div class="mb-3">
    <h5>Bot account @RoleBadge(status?.Bot)</h5>
    <a href='@botUrl'>Authorize Bot with bot account</a>
</div>
<div class="mb-3">
    <h5>Broadcaster account @RoleBadge(status?.Broadcaster)</h5>
    <a href='@streamerUrl'>Authorize Bot with stream account</a>
</div>

<ChatSendBox />

@code {
    private string botUrl = string.Empty;
    private string streamerUrl = string.Empty;
    private AuthStatusResponse? status;

    protected override void OnInitialized()
    {
        botUrl = AuthUrlBuilder.BuildBotAuthorizeUrl(Navigator.BaseUri);
        streamerUrl = AuthUrlBuilder.BuildBroadcasterAuthorizeUrl(Navigator.BaseUri);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            status = await TwitchApiClient.GetAuthStatus();
            StateHasChanged();
        }
    }

    private static string RoleBadge(RoleStatus? role) => role switch
    {
        null => "— not logged in",
        { NeedsLogin: true } => $"— {role.Login}: login expired, please log in again",
        _ => $"— logged in as {role.Login}",
    };
}
