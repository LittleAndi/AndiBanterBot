@page "/"
@using Web.Components.Dashboard
@using Web.Components.Services
@implements IAsyncDisposable
@inject TwitchApiClient TwitchApiClient
@inject TwitchAuthUrlBuilder AuthUrlBuilder
@inject NavigationManager Navigator
@rendermode InteractiveServer

<PageTitle>Dashboard</PageTitle>

<div class="dashboard">
    <StatusBand Status="status" Loading="loading" Refreshing="refreshing" OnRetry="RetryStatus" />

    <div class="dashboard-grid">
        <StreamStatusTile Status="streamStatus" Loading="loading" />
        @if (hypeTrainStatus is { IsActive: true } hypeTrain)
        {
            <ProgressTile Label="Hype Train" Icon="🚂" Detail="@($"Level {hypeTrain.Level}")" Current="hypeTrain.Progress" Target="hypeTrain.Goal" />
        }
        @if (goalStatus is { IsActive: true } goal)
        {
            <ProgressTile Label="Community Goal" Icon="🎯" Detail="@GoalTypeLabel(goal.Type)" Current="goal.CurrentAmount" Target="goal.TargetAmount" />
        }
        <AccountCard Title="Bot account" Role="status?.Bot" AuthorizeUrl="@botUrl" ActionLabel="Log in with bot account" />
        <AccountCard Title="Broadcaster account" Role="status?.Broadcaster" AuthorizeUrl="@streamerUrl" ActionLabel="Log in with broadcaster account" />
        <ChatSendBox />
    </div>

    @if (pollStatus is { IsActive: true })
    {
        <PollPanel Status="pollStatus" />
    }

    @if (predictionStatus is { IsActive: true })
    {
        <PredictionPanel Status="predictionStatus" />
    }

    <ActivityFeedPanel Items="activity" Loading="loading" />

    <ModerationLogPanel Items="moderationLog" Loading="loading" />

    <RewardsPanel Items="rewards" Loading="loading" OnToggled="HandleRewardToggled" />

    <section class="coming-soon">
        <h2 class="coming-soon-title">More on the way</h2>
        <ul class="coming-soon-list">
            <li>Live chat activity — will show up here once the bot streams it through</li>
            <li>PUBG match stats — the data's already flowing, just not to this screen yet</li>
            <li>Clip history</li>
        </ul>
    </section>
</div>

@code {
    private AuthStatusResponse? status;
    private StreamStatusResponse? streamStatus;
    private HypeTrainStatusResponse? hypeTrainStatus;
    private GoalStatusResponse? goalStatus;
    private PollStatusResponse? pollStatus;
    private PredictionStatusResponse? predictionStatus;
    private ActivityFeedItem[]? activity;
    private ModerationLogItem[]? moderationLog;
    private RewardItem[]? rewards;
    private bool loading = true;
    private bool refreshing;
    private string botUrl = string.Empty;
    private string streamerUrl = string.Empty;
    private PeriodicTimer? timer;

    protected override void OnInitialized()
    {
        botUrl = AuthUrlBuilder.BuildBotAuthorizeUrl(Navigator.BaseUri);
        streamerUrl = AuthUrlBuilder.BuildBroadcasterAuthorizeUrl(Navigator.BaseUri);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await FetchStatusAsync();
            StateHasChanged();
            _ = PollStatusAsync();
        }
    }

    private async Task FetchStatusAsync()
    {
        var statusTask = TwitchApiClient.GetAuthStatus();
        var streamStatusTask = TwitchApiClient.GetStreamStatus();
        var hypeTrainStatusTask = TwitchApiClient.GetHypeTrainStatus();
        var goalStatusTask = TwitchApiClient.GetGoalStatus();
        var pollStatusTask = TwitchApiClient.GetPollStatus();
        var predictionStatusTask = TwitchApiClient.GetPredictionStatus();
        var activityTask = TwitchApiClient.GetRecentActivity();
        var moderationLogTask = TwitchApiClient.GetRecentModerationLog();
        var rewardsTask = TwitchApiClient.GetRewards();
        await Task.WhenAll(statusTask, streamStatusTask, hypeTrainStatusTask, goalStatusTask, pollStatusTask, predictionStatusTask, activityTask, moderationLogTask, rewardsTask);

        status = statusTask.Result;
        streamStatus = streamStatusTask.Result;
        hypeTrainStatus = hypeTrainStatusTask.Result;
        goalStatus = goalStatusTask.Result;
        pollStatus = pollStatusTask.Result;
        predictionStatus = predictionStatusTask.Result;
        activity = activityTask.Result;
        moderationLog = moderationLogTask.Result;
        rewards = rewardsTask.Result;
        loading = false;
    }

    // A pause/unpause toggle is a one-off write, not gated by the 15s poll cycle - update the
    // affected reward in place so the toggle reflects instantly instead of waiting for the next tick.
    private void HandleRewardToggled(RewardItem updated)
    {
        if (rewards is null)
        {
            return;
        }

        rewards = [.. rewards.Select(r => r.Id == updated.Id ? updated : r)];
    }

    // Twitch goal `type` values are terse identifiers, not display text.
    private static string GoalTypeLabel(string type) => type switch
    {
        "follow" => "Follower goal",
        "subscription" => "Subscription points goal",
        "subscription_count" => "Subscriber count goal",
        "new_subscription" => "New subscription points goal",
        "new_subscription_count" => "New subscriber count goal",
        _ => "Community goal"
    };

    private async Task RetryStatus()
    {
        refreshing = true;
        await FetchStatusAsync();
        refreshing = false;
        StateHasChanged();
    }

    private async Task PollStatusAsync()
    {
        timer = new PeriodicTimer(TimeSpan.FromSeconds(15));
        try
        {
            while (await timer.WaitForNextTickAsync())
            {
                await FetchStatusAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (ObjectDisposedException)
        {
            // Timer disposed on component teardown; stop polling silently.
        }
    }

    public ValueTask DisposeAsync()
    {
        timer?.Dispose();
        return ValueTask.CompletedTask;
    }
}
