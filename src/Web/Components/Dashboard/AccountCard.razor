@using Web.Components.Services

<div class="account-card">
    <h2 class="account-title">@Title</h2>

    @if (Role is null)
    {
        <p class="account-status account-status--muted">Not logged in yet.</p>
        <a class="account-action account-action--primary" href="@AuthorizeUrl">@ActionLabel</a>
    }
    else if (Role.NeedsLogin)
    {
        <p class="account-status account-status--attention">
            <svg class="account-icon" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M8 1.5 1 14h14L8 1.5Z" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" />
                <path d="M8 6.2v3.4M8 11.6v.1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
            </svg>
            Login expired for <span class="mono">@Role.Login</span>
        </p>
        <a class="account-action account-action--primary" href="@AuthorizeUrl">@ActionLabel</a>
    }
    else
    {
        <p class="account-status account-status--ok">
            <svg class="account-icon" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M3 8.5 6.5 12 13 4.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            Logged in as <span class="mono">@Role.Login</span>
        </p>
        <a class="account-action account-action--quiet" href="@AuthorizeUrl">Re-authorize</a>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public RoleStatus? Role { get; set; }
    [Parameter, EditorRequired] public string AuthorizeUrl { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string ActionLabel { get; set; } = string.Empty;
}
