@using Web.Components.Services

<div class="stream-tile stream-tile--@StateClass">
    <span class="stream-icon" aria-hidden="true">
        @if (StateClass == "live")
        {
            <svg viewBox="0 0 16 16">
                <circle cx="8" cy="8" r="8" fill="currentColor" />
            </svg>
        }
        else if (StateClass == "offline")
        {
            <svg viewBox="0 0 16 16">
                <circle cx="8" cy="8" r="6.5" fill="none" stroke="currentColor" stroke-width="1.5" />
            </svg>
        }
        else
        {
            <svg viewBox="0 0 16 16">
                <path d="M8 1.5 1 14h14L8 1.5Z" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" />
                <path d="M8 6.2v3.4M8 11.6v.1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
            </svg>
        }
    </span>

    <div class="stream-text">
        @if (Loading)
        {
            <span class="stream-headline skeleton">Checking stream…</span>
        }
        else if (Status is null)
        {
            <span class="stream-headline">Can't reach stream status</span>
            <span class="stream-detail">The dashboard couldn't load the current stream state.</span>
        }
        else if (Status.IsLive is null)
        {
            <span class="stream-headline">Stream status unknown</span>
            <span class="stream-detail">Log in with the broadcaster account to enable it.</span>
        }
        else if (Status.IsLive.Value)
        {
            <span class="stream-headline">Live</span>
            <span class="stream-detail">
                @if (Status.StartedAt is not null)
                {
                    <text>Since <time class="mono">@Status.StartedAt.Value.ToLocalTime().ToString("t")</time></text>
                }
            </span>
        }
        else
        {
            <span class="stream-headline">Offline</span>
            <span class="stream-detail">Not currently streaming</span>
        }
    </div>
</div>

@code {
    [Parameter] public StreamStatusResponse? Status { get; set; }
    [Parameter] public bool Loading { get; set; }

    private string StateClass
    {
        get
        {
            if (Loading) return "loading";
            if (Status is null) return "unreachable";
            if (Status.IsLive is null) return "unknown";
            return Status.IsLive.Value ? "live" : "offline";
        }
    }
}
